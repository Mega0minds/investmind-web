# Copy to `.env.local` for local dev, or set these in your host (e.g. Vercel → Environment Variables).
# Never commit `.env.local` or real keys.

# --- Required (app will throw at runtime if missing) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# --- Strongly recommended for production ---
# Canonical site URL (https, no trailing slash). Used for email redirects and metadata.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# --- Optional (server-only; never expose to the client) ---
# Admin / server routes that use the service role (keep unset in local dev if unused).
# SUPABASE_SERVICE_ROLE_KEY=

# Super admin email: full sidebar + cannot be edited from Verification UI. Defaults in code if unset.
# SUPER_ADMIN_EMAIL=emperorshubnetwork@gmail.com
