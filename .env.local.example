# Copy to .env.local and fill in from Supabase → Project Settings → API
# Restart `npm run dev` after any change.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# Canonical site URL (SEO, emails, server code). OAuth from the browser uses whatever origin
# you are on (localhost, Vercel preview, production), so list every callback you use in Supabase:
#   Authentication → URL Configuration → Redirect URLs:
#   http://localhost:3000/auth/callback
#   https://YOUR_APP.vercel.app/auth/callback
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only (API routes / scripts). Never expose in the browser.
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
